# OpenRouter API Configuration
# Ersetze 'your-api-key-here' mit deinem echten API-Key
OPENROUTER_API_KEY= 'HIER BITTE API KEY EINFÜGEN'

# Optional: Modell-Konfiguration (Standard-Werte werden verwendet, wenn nicht gesetzt)
# LLM_MODEL=qwen/qwen3-vl-30b-a3b-instruct
# AUDIO_MODEL=openai/whisper-large-v3-turbo

# Anleitung:
# 1. Kopiere diese Datei zu .env: cp .env.example .env
# 2. Trage deinen OpenRouter API-Key ein
# 3. Installiere python-dotenv: pip install python-dotenv
